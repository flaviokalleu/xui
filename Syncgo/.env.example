# ===== TELEGRAM (obrigatório) =====
# Pegue API_ID e API_HASH em https://my.telegram.org → API development tools
API_ID=22594796
API_HASH=ef1f82927273518ebb576665d7c63a55

# Token do bot (crie em @BotFather no Telegram)
BOT_TOKEN=5683945052:AAEqmBd81uTL2wJ8ZXpEL-fl2oGcBoK3wrc

# ID do canal Telegram onde os arquivos ficam guardados.
# Formato: -100 + número que aparece em https://web.telegram.org/k/#-XXXXXXXXX
# IMPORTANTE: o bot precisa ser ADMIN deste canal.
LOG_CHANNEL=-1003718091048

# ===== HTTP =====
PORT=8080
BIND_ADDRESS=0.0.0.0

HAS_SSL=false
NO_PORT=false

# ===== XUI MySQL (opcional — ativa auto-insert no painel) =====
# Quando configurado, todo arquivo enviado pro bot é automaticamente inserido
# no painel XUI ONE com base no nome do arquivo:
#   240022.mp4         → filme TMDB 240022
#   240022_S01E02.mp4  → episódio S01E02 da série TMDB 240022
XUI_HOST=
XUI_PORT=3306
XUI_USER=
XUI_PASSWORD=
XUI_DATABASE=xui
XUI_SERVER_ID=1

# ===== TMDB (necessário se XUI estiver ativo) =====
# Pegue uma chave grátis em https://www.themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_LANGUAGE=pt-BR

# ===== Avançado =====
SLEEP_THRESHOLD=60
WORKERS=4
DB_PATH=./syncgo.db
SESSION_DIR=./sessions
OWNER_ID=0
ADMINS=
MULTI_TOKENS=
# AUTO_INSERT padrão: ligado se XUI estiver configurado.
# AUTO_INSERT=true

# ===== Segurança / Operação =====
# Segredo do HMAC dos hashes de URL. Default: derivado do BOT_TOKEN.
# HASH_SECRET=algumacoisarandomicasua
RATE_LIMIT_PER_MIN=120
SHUTDOWN_TIMEOUT=30
METRICS_ENABLED=true

# ===== XUI reload via SSH (opcional) =====
# Quando configurado, depois de inserts o painel é recarregado automaticamente.
# Default debounce: 30s (vários inserts viram 1 reload).
# XUI_SSH_HOST=                # default: mesmo do XUI_HOST
# XUI_SSH_PORT=22
# XUI_SSH_USER=root
# XUI_SSH_PASSWORD=
# XUI_RELOAD_CMD=sudo service xuione reload
# XUI_RELOAD_DEBOUNCE_SEC=30
